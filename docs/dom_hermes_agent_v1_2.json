{
  "_meta": {
    "document": "DŌM Home Café — Brand & Menu Data for Herms Agent",
    "version": "1.2",
    "prepared_for": "Herms Agent — DŌM Home Café OS Build",
    "notes": "Corrected for the agreed MVP: DOM brand/UI only, operational home coffee categories, no prices, no small plates, no equipment field."
  },
  "brand": {
    "name": "DŌM",
    "name_ascii": "DOM",
    "type": "Home Café",
    "tagline": "Slow coffee. Deep roots.",
    "tagline_alternates": [
      "Brewed from memory.",
      "Where the morning settles.",
      "Rooted. Poured. Present."
    ],
    "origin": "Nubian-inspired — named after the Doum palm, commonly known botanically as Hyphaene thebaica. The brand uses the tree as a symbol of depth, patience, rootedness, and home.",
    "philosophy": "Slowness is the condition under which quality becomes possible. Every item is made at the pace it requires, not the pace a clock demands.",
    "voice": {
      "tone": [
        "Warm",
        "Unhurried",
        "Grounded",
        "Friendly",
        "Certain without arrogance"
      ],
      "style": "Short sentences. Concrete images. No jargon. Speak the way an old friend speaks.",
      "avoid": [
        "Trendy coffee jargon",
        "Over-explanation",
        "Urgency cues",
        "Superlatives"
      ]
    }
  },
  "design_tokens": {
    "colors": {
      "nubian_night": {
        "hex": "#2C2C2A",
        "role": "primary background, headlines, dark surfaces"
      },
      "doum_gold": {
        "hex": "#BA7517",
        "role": "accent, dividers, macron mark, CTAs"
      },
      "palm_dust": {
        "hex": "#F1EFE8",
        "role": "page background, card surfaces, reversed text on dark"
      },
      "nile_mist": {
        "hex": "#5DCAA5",
        "role": "highlight, refreshing items, seasonal accents"
      },
      "fired_clay": {
        "hex": "#D85A30",
        "role": "warmth cues, spiced drinks, friendly alerts"
      },
      "mid_tone": {
        "hex": "#888780",
        "role": "secondary text, descriptions, labels"
      },
      "hint": {
        "hex": "#B4B2A9",
        "role": "tertiary text, placeholders, dividers"
      },
      "light_rule": {
        "hex": "#D3D1C7",
        "role": "hairline rules, borders"
      }
    },
    "typography": {
      "display": {
        "font": "serif or thin sans",
        "weight": 300,
        "tracking": "0.3em+",
        "use": "DŌM wordmark moments"
      },
      "heading": {
        "font": "sans-serif",
        "weight": 300,
        "tracking": "0.15em",
        "use": "section titles, category headers"
      },
      "subhead": {
        "font": "sans-serif",
        "weight": 400,
        "tracking": "normal",
        "use": "drink names"
      },
      "body": {
        "font": "sans-serif",
        "weight": 400,
        "size": "14–16px",
        "line_height": "1.7",
        "use": "descriptions, story copy"
      },
      "label": {
        "font": "sans-serif",
        "weight": 400,
        "tracking": "wide",
        "case": "UPPERCASE",
        "size": "11px",
        "use": "tags, categories, metadata"
      }
    },
    "arabic_fonts": {
      "primary": "Tajawal",
      "fallbacks": [
        "Cairo",
        "Almarai"
      ],
      "requirement": "Fonts must be loaded by the web app, not dependent on client-installed fonts."
    },
    "spacing": {
      "base_unit": "8px",
      "section_gap": "48px",
      "item_gap": "24px",
      "card_padding": "24px"
    },
    "border_radius": "8px",
    "logo_clear_space": "equal to height of M character in the wordmark"
  },
  "mvp_rules": {
    "pricing": "No prices in MVP. This is a private home café guest experience, not a sales menu.",
    "photos": "Every drink must have a photo_url. Seed drinks may use placeholders until replaced by admin.",
    "beans": "Admin selects a default bean for each drink. Guest sees the bean but cannot choose it in MVP.",
    "equipment": "Do not include tool/equipment fields.",
    "categories_editable": true,
    "drinks_editable": true,
    "availability": "Admin can toggle availability for categories, drinks, and beans.",
    "order_progress": {
      "controlled_by": "admin",
      "guest_can_change_status": false,
      "polling_seconds": 15,
      "statuses": [
        "new",
        "received",
        "preparing",
        "ready",
        "cancelled"
      ],
      "guest_labels": {
        "new": "Your order was sent to the bar.",
        "received": "Your order was received.",
        "preparing": "Your drink is being prepared.",
        "ready": "Your drink is ready — we’ll bring it to you shortly.",
        "cancelled": "This order was cancelled. Please check with the coffee bar."
      }
    }
  },
