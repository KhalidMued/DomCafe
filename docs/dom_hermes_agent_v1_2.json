  "digital_menu_ui_rules": {
    "layout": "Single-scroll vertical feed, category anchors in sticky nav",
    "default_theme": "dark (nubian_night background, palm_dust text)",
    "light_theme_available": true,
    "navigation": {
      "type": "sticky top bar, horizontal scroll tabs",
      "tab_labels": "Use category label; Arabic label may appear below or beside it later.",
      "active_tab_indicator": "doum_gold underline"
    },
    "item_card": {
      "show_fields": [
        "photo",
        "name",
        "name_ar",
        "description",
        "bean",
        "temperature_options",
        "milk_options",
        "availability"
      ],
      "tap_item": "Expand to show full description, bean details, ingredients, and options."
    },
    "footer": {
      "copy": "Slow coffee. Deep roots.",
      "copy_ar": "قهوة بطيئة. جذور عميقة.",
      "show_origin_note": true,
      "origin_note": "DŌM is named after the Doum palm — a symbol of patience, depth, and home."
    }
  },
  "three_js_rules": {
    "enabled": "optional",
    "allowed_locations": [
      "welcome_page_only"
    ],
    "allowed_ideas": [
      "Soft floating DŌM logo mark in the background",
      "Gentle animated bean/palm-inspired object",
      "Small interactive menu card tilt effect",
      "Subtle rotating 3D coffee cup sleeve on the welcome page"
    ],
    "requirements": [
      "Lazy load Three.js",
      "Do not block page load",
      "Provide static fallback if WebGL fails",
      "Do not use Three.js on menu, cart, or order tracking"
    ]
  },
