# Environment and secrets
.env
.env.*
!.env.example
secrets/*
!secrets/.gitkeep
certs/*
!certs/.gitkeep

# Python
__pycache__/
*.py[cod]
.venv/
.pytest_cache/
.mypy_cache/
.ruff_cache/

# Node
node_modules/
dist/
.vite/
coverage/

# Runtime data
*.log
.DS_Store
uploads/**/*.tmp
# Admin-panel uploads are runtime data. Already tracked/curated menu images
# remain in Git; promote new curated assets explicitly with `git add -f`.
uploads/drinks/*

# Docker
*.pid

# Claude Code local settings
.claude/settings.local.json*
